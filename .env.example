# ──────────────────────────────────────────────────────
# Attention-Aware Study Assistant — Environment Variables
# ──────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─── LLM Provider (pick one or both) ─────────────────
# Option 1: Google Gemini (paste your API key from AI Studio)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Option 2: Ollama (offline — just install and run `ollama serve`)
OLLAMA_URL=http://localhost:11434

# Option 3: Anthropic Claude (optional)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Priority: Gemini (if key set) → Ollama (if running) → Anthropic

# ─── YouTube Data API v3 ─────────────────────────────
YOUTUBE_API_KEY=

# ─── Sarvam AI (for transcription) ───────────────────
SARVAM_API_KEY=

# ─── Database ────────────────────────────────────────
DATABASE_URL=sqlite:///./data/study_assistant.db

# ─── Service URLs (for cloud deployment) ─────────────
ORCHESTRATOR_URL=http://localhost:8000
ATTENTION_MONITOR_URL=http://localhost:8001
LEARNER_PROFILER_URL=http://localhost:8002
CONTENT_ADAPTER_URL=http://localhost:8003
QUIZ_ENGINE_URL=http://localhost:8004
DATA_STORE_URL=http://localhost:8005
VIDEO_FATIGUE_URL=http://localhost:8006
YOUTUBE_REC_URL=http://localhost:8007
SUMMARY_URL=http://localhost:8008

